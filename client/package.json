{
  "name": "universal-clipboard",
  "version": "1.0.0",
  "description": "Universal Clipboard Sync",
  "author": "",
  "license": "ISC",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win portable",
    "build:mac": "electron-builder --mac",
    "build": "electron-builder"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yourname.universalclipboard",
    "productName": "Universal Clipboard",
    "asar": true,
    "files": [
      "**/*",
      "!node_modules/.cache/**"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "UniversalClipboard-Portable.exe"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    }
  }
}
